{
  "lastChangelogVersion": "0.74.0",
  "defaultProvider": "anthropic",
  "theme": "onedark-pro",
  "defaultModel": "claude-sonnet-4-6",
  "defaultThinkingLevel": "medium",
  "packages": [
    "npm:pi-powerline-footer",
    "npm:pi-custom-compaction",
    "npm:@juicesharp/rpiv-ask-user-question",
    "npm:pi-lsp-extension",
    "npm:pi-web-access",
    "npm:vim-motions-pi",
    "npm:pi-answer"
  ],
  "compaction": {
    "enabled": true
  },
  "workingVibe": "adeptus mechanicus",
  "workingVibeMode": "file",
  "workingVibeFallback": "Praising the Omnissiah",
  "showLastPrompt": false,
  "powerline": {
    "preset": "default",
    "fixedEditor": true,
    "mouseScroll": true,
    "customItems": [
      {
        "id": "agent-mode",
        "statusKey": "agent-mode",
        "position": "left",
        "hideWhenMissing": false,
        "excludeFromExtensionStatuses": true
      },
      {
        "id": "kube",
        "statusKey": "kube",
        "position": "secondary",
        "hideWhenMissing": true,
        "excludeFromExtensionStatuses": true
      },
      {
        "id": "aws",
        "statusKey": "aws",
        "position": "secondary",
        "hideWhenMissing": true,
        "excludeFromExtensionStatuses": true
      },
      {
        "id": "vim-mode",
        "statusKey": "vim-mode",
        "position": "secondary-right",
        "hideWhenMissing": false,
        "excludeFromExtensionStatuses": true
      },
      {
        "id": "note-vault",
        "statusKey": "note-vault",
        "position": "secondary",
        "color": "accent",
        "hideWhenMissing": true,
        "excludeFromExtensionStatuses": true
      }
    ]
  },
  "powerlineShortcuts": {
    "stashHistory": "ctrl+alt+h",
    "copyEditor": "ctrl+alt+c",
    "cutEditor": "ctrl+alt+x"
  },
  "editorPaddingX": 0,
  "shellCommandPrefix": "shopt -s expand_aliases\nsource ~/.bash_aliases 2>/dev/null",
  "steeringMode": "one-at-a-time",
  "doubleEscapeAction": "tree",
  "quietStartup": true,
  "treeFilterMode": "default",
  "warnings": {
    "anthropicExtraUsage": true
  }
}