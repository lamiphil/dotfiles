{
  "$schema": "https://www.schemastore.org/claude-code-keybindings.json",
  "$docs": "https://code.claude.com/docs/en/keybindings",
  "bindings": [
    {
      "context": "Transcript",
      "bindings": {
        "ctrl+shift+k": "scroll:lineUp",
        "ctrl+shift+j": "scroll:lineDown"
      }
    },
    {
      "context": "Scroll",
      "bindings": {
        "ctrl+shift+k": "scroll:lineUp",
        "ctrl+shift+j": "scroll:lineDown"
      }
    }
  ]
}
