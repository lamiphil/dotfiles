{
  // General
  "layer": "top",
  "position": "top",
  "height": 42,
  "spacing": 0,

  // Load modules
  "include": ["~/.config/waybar/modules.json"],

  // Left modules
  "modules-left": [
    "hyprland/workspaces"
  ],

  // Center modules
  "modules-center": ["custom/clock"],

  // Right modules
  "modules-right": [
    "tray",
    "network",
    "bluetooth",
    "pulseaudio",
    "battery",
    "custom/power"
  ]
}

