{
  // General
  "layer": "top",
  "position": "top",
  "height": 34,
  "spacing": 10,

  // Load modules
  "include": ["~/.config/waybar/modules.json"],

  // Left modules
  "modules-left": [
    "hyprland/workspaces"
  ],

  // Center modules
  "modules-center": ["clock"],

  // Right modules
  "modules-right": [
    "tray",
    "network",
    "pulseaudio",
    "battery",
    "cpu",
    "memory",
    "custom/weather",
    "custom/power"
  ]
}

