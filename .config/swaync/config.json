{
  "$schema": "/etc/xdg/swaync/configSchema.json",
  "positionX": "right",
  "positionY": "top",
  "control-center-margin-top": 6,
  "control-center-margin-right": 6,
  "control-center-margin-bottom": 6,
  "control-center-width": 420,
  "notification-window-width": 380,
  "notification-window-height": -1,
  "layer-shell": true,
  "layer-shell-cover-screen": false,
  "fit-to-screen": true,
  "keyboard-shortcuts": true,
  "image-visibility": "when-available",
  "transition-time": 180,
  "hide-on-clear": true,
  "hide-on-action": true,
  "timeout": 6,
  "timeout-low": 5,
  "timeout-critical": 0,
  "notification-icon-size": 44,
  "notification-body-image-height": 180,
  "notification-body-image-width": 180,
  "widgets": [
    "buttons-grid#connect",
    "buttons-grid#dnd",
    "buttons-grid#system",
    "mpris",
    "label#volume-title",
    "volume",
    "title",
    "notifications"
  ],
  "widget-config": {
    "title": {
      "text": "Notifications",
      "clear-all-button": true,
      "button-text": "Clear All"
    },
    "buttons-grid#connect": {
      "buttons-per-row": 2,
      "actions": [
        {
          "label": "󰂯  Bluetooth",
          "command": "blueman-manager"
        },
        {
          "label": "󰤨  Network",
          "command": "nm-connection-editor"
        }
      ]
    },
    "buttons-grid#dnd": {
      "buttons-per-row": 1,
      "actions": [
        {
          "label": "󰂚",
          "type": "toggle",
          "active": false,
          "command": "sh -c 'swaync-client -d -sw >/dev/null'",
          "update-command": "sh -c '[[ $(swaync-client -D) == false ]] && echo true || echo false'"
        }
      ]
    },
    "buttons-grid#system": {
      "buttons-per-row": 4,
      "actions": [
        {
          "label": "",
          "command": "sh -c 'swaync-client -cp; hyprlock'"
        },
        {
          "label": "",
          "command": "sh -c 'swaync-client -cp; hyprctl dispatch exit'"
        },
        {
          "label": "󰑓",
          "command": "sh -c 'swaync-client -cp; systemctl reboot'"
        },
        {
          "label": "",
          "command": "sh -c 'swaync-client -cp; systemctl poweroff'"
        }
      ]
    },
    "mpris": {
      "autohide": true,
      "loop-carousel": true,
      "show-album-art": "when-available",
      "image-size": 72,
      "image-radius": 18
    },
    "label#volume-title": {
      "text": "Volume"
    },
    "volume": {
      "label": "󰕾",
      "show-per-app": false
    }
  }
}
